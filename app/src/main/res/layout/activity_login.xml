<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:gravity="center"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".LoginActivity">
    <ImageView
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:src="@drawable/ic_main"
        android:padding="16dp"
        android:background="@drawable/loader_img"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="HAAi"
        android:textSize="16sp"
        android:textStyle="bold"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Health Assistant Artificial Intelligence"
        android:textSize="14sp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:orientation="vertical"
        android:gravity="center">
        <TextView
            android:id="@+id/loginWgooleBtn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Login with GOOGLE"
            android:textStyle="bold"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:background="@drawable/curved_blue_outliner"
            android:visibility="visible"/>
        <LinearLayout
            android:id="@+id/loginDetailLL"
            android:layout_width="match_parent"
            android:visibility="gone"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:id="@+id/emailTv"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="emailuser@gmail.com"
                android:layout_marginHorizontal="16dp"
                android:padding="8dp"
                android:textColor="@color/text_white"
                android:background="@drawable/blue_bubble"
                android:layout_marginVertical="8dp"/>
            <EditText
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:padding="12dp"
                android:hint="Enter Name"
                android:layout_marginBottom="8dp"
                android:background="@drawable/curver_outliner"
                android:id="@+id/nameEt"/>
            <LinearLayout
                android:gravity="center"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="16dp"
                    android:padding="12dp"
                    android:textSize="16dp"
                    android:hint="Date of Birth"
                    android:background="@drawable/curver_outliner"
                    android:id="@+id/dobInput"/>
                <TextView
                    android:id="@+id/maleBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:textSize="18sp"
                    android:textAlignment="center"
                    android:paddingHorizontal="14dp"
                    android:paddingVertical="8dp"
                    android:text="Male"
                    android:background="@drawable/curver_outliner"/>
                <TextView
                    android:id="@+id/femaleBtn"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:textSize="18sp"
                    android:textAlignment="center"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginLeft="2dp"
                    android:text="Female"
                    android:background="@drawable/curver_outliner"/>

            </LinearLayout>
            <Button
                android:id="@+id/nextpage"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="LOGIN"
                android:layout_gravity="center"
                android:layout_margin="24dp"
                android:backgroundTint="@color/primary_blue_dark"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </LinearLayout>
    </LinearLayout>





</LinearLayout>