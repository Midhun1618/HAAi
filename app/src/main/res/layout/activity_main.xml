<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity"
    android:paddingHorizontal="8dp">
    <TextView
        android:id="@+id/greetingTv"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Hi, Username"
        android:layout_marginHorizontal="18dp"
        android:textSize="18sp"
        android:layout_marginTop="18dp"/>
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="8dp"
        android:layout_margin="18dp"
        android:elevation="16dp"
        app:cardCornerRadius="16dp">
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <ImageView
                android:src="@drawable/ic_android_black_24dp"
                android:layout_width="70dp"
                android:layout_height="70dp"
                android:layout_margin="8dp"/>
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:gravity="center_vertical">
                <TextView
                    android:id="@+id/usernameTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="UserName"
                    android:layout_margin="3dp"
                    android:textSize="15sp"/>
                <TextView
                    android:id="@+id/ageweightTv"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Age : 28    Weight : 40kg"
                    android:layout_margin="3dp"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>



    </androidx.cardview.widget.CardView>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingTop="20dp"
        android:elevation="5dp"
        android:layout_marginHorizontal="8dp"
        android:background="@drawable/top_curved_blue_container"
        android:gravity="center_horizontal"
        android:orientation="vertical">
        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:horizontalSpacing="8dp"
            android:verticalSpacing="8dp">
            <androidx.cardview.widget.CardView
                android:id="@+id/card1"
                android:layout_width="150dp"
                app:cardCornerRadius="18dp"
                android:elevation="8dp"
                android:layout_margin="8dp"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:src="@drawable/ic_android_black_24dp"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_margin="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Check Symptoms"
                        android:layout_margin="8dp"
                        android:textSize="15sp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/card2"
                android:layout_width="wrap_content"
                app:cardCornerRadius="18dp"
                android:layout_margin="8dp"
                android:elevation="8dp"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="150dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:src="@drawable/ic_android_black_24dp"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_margin="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Health Tips"
                        android:layout_margin="8dp"
                        android:textSize="15sp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/card3"
                android:layout_width="wrap_content"
                app:cardCornerRadius="18dp"
                android:elevation="8dp"
                android:layout_margin="7dp"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="150dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:src="@drawable/ic_android_black_24dp"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_margin="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reports"
                        android:layout_margin="8dp"
                        android:textSize="15sp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/card4"
                android:layout_width="wrap_content"
                app:cardCornerRadius="18dp"
                android:elevation="8dp"
                android:layout_margin="7dp"
                android:layout_height="wrap_content">
                <LinearLayout
                    android:layout_width="150dp"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center">
                    <ImageView
                        android:src="@drawable/ic_android_black_24dp"
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_margin="8dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Emergency Help"
                        android:layout_margin="8dp"
                        android:textSize="15sp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

        </GridLayout>
    </LinearLayout>


</LinearLayout>