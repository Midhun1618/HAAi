<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SymptomsActivity">
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Your Symptoms"
        android:layout_marginHorizontal="16dp"
        android:textSize="22sp"
        android:textColor="@color/primary_blue_dark"
        android:textStyle="bold"
        android:layout_marginTop="50dp"/>
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/text_secondary"
        android:layout_marginTop="15dp"
        android:layout_marginBottom="8dp"
        android:layout_marginHorizontal="16dp"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:background="@drawable/curver_outliner"
        android:orientation="horizontal">
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:orientation="vertical">
            <Button
                android:id="@+id/symp1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="Fever"
                android:layout_marginBottom="4dp"
                android:backgroundTint="@color/text_secondary"/>
            <Button
                android:id="@+id/symp2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="Cough"
                android:layout_marginBottom="4dp"
                android:backgroundTint="@color/text_secondary"/>
            <Button
                android:id="@+id/symp3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="Headache"
                android:layout_marginBottom="4dp"
                android:backgroundTint="@color/text_secondary"/>
            <Button
                android:id="@+id/symp4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="Body Pain"
                android:layout_marginBottom="4dp"
                android:backgroundTint="@color/text_secondary"/>
            <Button
                android:id="@+id/symp5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="Nausea"
                android:layout_marginBottom="4dp"
                android:backgroundTint="@color/text_secondary"/>


        </LinearLayout>
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_margin="8dp"
            android:orientation="vertical">
            <Button
                android:id="@+id/symp6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="Vomiting"
                android:layout_marginBottom="4dp"
                android:backgroundTint="@color/text_secondary"/>
            <Button
                android:id="@+id/symp7"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="Diarrhea"
                android:layout_marginBottom="4dp"
                android:backgroundTint="@color/text_secondary"/>
            <Button
                android:id="@+id/symp8"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="Fatigue"
                android:layout_marginBottom="4dp"
                android:backgroundTint="@color/text_secondary"/>
            <Button
                android:id="@+id/symp9"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="Sore Throat"
                android:layout_marginBottom="4dp"
                android:backgroundTint="@color/text_secondary"/>
            <Button
                android:id="@+id/symp10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:text="Chest pain"
                android:layout_marginBottom="4dp"
                android:backgroundTint="@color/text_secondary"/>

        </LinearLayout>
    </LinearLayout>
    <EditText
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:padding="12dp"
        android:hint="Additional Inputs"
        android:background="@drawable/curver_outliner"
        android:id="@+id/additionalInput"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginHorizontal="16dp"
        android:layout_marginBottom="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:padding="4dp"
            android:text="Duration"/>
        <EditText
            android:id="@+id/durationEt"
            android:layout_width="60dp"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:inputType="number"
            android:hint="Days"
            android:background="@drawable/curver_outliner"
            android:layout_marginVertical="4dp"/>
        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:padding="4dp"
            android:text="Age"/>
        <EditText
            android:id="@+id/ageEt"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:padding="8dp"
            android:inputType="number"
            android:hint="Years"
            android:background="@drawable/curver_outliner"
            android:layout_marginVertical="4dp"/>
    </LinearLayout>


    <Button
        android:id="@+id/checkNow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="12sp"
        android:text="CHECK NOW"
        android:backgroundTint="@color/primary_blue"
        android:layout_margin="16dp"/>

</LinearLayout>